{
  "expo": {
    "name": "Eats",
    "slug": "diogo-eats",
    "owner": "diogo-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0a",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pt.thunderfusion.eats"
    },
    "android": {
